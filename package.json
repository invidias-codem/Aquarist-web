{
  "name": "aquarist-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "tsc -b",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.8",
    "tsx": "^4.23.0",
    "turbo": "latest",
    "typescript": "~6.0.2"
  },
  "packageManager": "npm@10.9.8",
  "dependencies": {
    "zod": "^4.4.3"
  }
}
